# Supabase API (рекомендуется для Cloud Run: без пароля БД)
# Publishable Key из дашборда Supabase (не "Anon Key (Legacy)").
# Бэкенд читает: VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY или SUPABASE_PUBLISHABLE_DEFAULT_KEY
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_***

# Database direct (опционально: для краулера/docs/vector search; локально для полного функционала)
# Local: postgresql+asyncpg://postgres:postgres@localhost:5432/tz-hz
# Supabase direct: postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.xxx.supabase.co:5432/postgres
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tz-hz

# Crawler settings
CRAWL_BASE_URL=https://elma365.com
CRAWL_MAX_DEPTH=10
CRAWL_DELAY=1.0
CRAWL_MAX_CONCURRENT=5

# Output settings
OUTPUT_DIR=data/crawled

# Logging
LOG_LEVEL=INFO

# LLM settings (DeepSeek V3.2 for agents - reasoning-first model built for agents)
# DeepSeek-V3.2: Supports "Thinking in Tool-Use" - REQUIRED for agents with MCP tools
#   Standard endpoint (RECOMMENDED):
#     DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
#     DEEPSEEK_MODEL=deepseek-chat
#
# DeepSeek-V3.2-Speciale: Advanced reasoning, but NO tool calls support
#   WARNING: Agents with MCP tools will fail! Use only for non-agent tasks.
#   Special endpoint (until Dec 15, 2025):
#     DEEPSEEK_API_URL=https://api.deepseek.com/v3.2_speciale_expires_on_20251215
#     DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Embeddings settings (MUST remain on OpenAI)
OPENAI_API_KEY=sk-proj-S95YAqB
OPENAI_MODEL_EMBEDDING=text-embedding-3-small
OPENAI_API_URL_EMBEDDING=https://api.openai.com/v1/embeddings

# Frontend (for Vercel): API URL of backend (e.g. Cloud Run)
# VITE_API_URL=https://your-backend.run.app

# MCP settings
MCP_SERVER_MODE=http

